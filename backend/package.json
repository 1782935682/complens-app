{
  "name": "compcheck-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "ingredient:inventory": "node --import tsx scripts/ingredient-official-data-pipeline.ts inventory",
    "ingredient:fetch": "node --import tsx scripts/ingredient-official-data-pipeline.ts fetch",
    "ingredient:extract": "node --import tsx scripts/ingredient-official-data-pipeline.ts extract",
    "ingredient:import-staging": "node --import tsx scripts/ingredient-official-data-pipeline.ts import-staging",
    "ingredient:promote": "node --import tsx scripts/ingredient-official-data-pipeline.ts promote",
    "ingredient:report": "node --import tsx scripts/ingredient-official-data-pipeline.ts report",
    "ingredient:promote-reviewed": "node --import tsx scripts/promote-reviewed-ingredient-data.ts",
    "ingredient:update-all": "node --import tsx scripts/ingredient-official-data-pipeline.ts inventory && node --import tsx scripts/ingredient-official-data-pipeline.ts fetch && node --import tsx scripts/ingredient-official-data-pipeline.ts extract && node --import tsx scripts/import-ingredient-knowledge.ts && node --import tsx scripts/import-ordinary-ingredient-seed.ts && node --import tsx scripts/validate-ingredient-knowledge.ts && node --import tsx scripts/generate-ingredient-coverage.ts",
    "ingredient:sources": "node --import tsx scripts/fetch-ingredient-sources.ts",
    "ingredient:import": "node --import tsx scripts/import-ingredient-knowledge.ts",
    "ingredient:ordinary-seed": "node --import tsx scripts/import-ordinary-ingredient-seed.ts",
    "ingredient:validate": "node --import tsx scripts/validate-ingredient-knowledge.ts",
    "ingredient:coverage": "node --import tsx scripts/generate-ingredient-coverage.ts",
    "map:gb2760": "tsx scripts/auto-map-gb2760-ingredients.ts",
    "promote:gb2760": "tsx scripts/promote-gb2760.ts",
    "validate:gb2760": "tsx scripts/validate-gb2760.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
